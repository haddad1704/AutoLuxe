# --- Backend (Django) ---
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=autoluxe-tq4k.onrender.com

# CORS for the React frontend
CORS_ALLOWED_ORIGINS=https://autoluxe-tq4k.onrender.com,https://auto-luxe-delta.vercel.app
FRONTEND_URL=https://autoluxe-tq4k.onrender.com/

# SSLCommerz credentials (keep secret)
SSL_STORE_ID=replace-me
SSL_API_KEY=replace-me

# --- Database (Postgres) ---
USE_POSTGRES=true
POSTGRES_DB=autoluxe
POSTGRES_USER=autoluxe
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Ports exposed on the host machine ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend build arg ---
REACT_APP_API_BASE_URL=https://autoluxe-tq4k.onrender.com/